# PostgreSQL connection string.
# This project connects directly via the `pg` driver adapter (not Prisma Accelerate),
# so use a plain postgres:// URL — NOT one starting with prisma+postgres://
DATABASE_URL=your_postgresql_connection_string

# Secret used to sign admin login sessions (JWT). Use a long random string.
# Generate one with: openssl rand -base64 32
JWT_SECRET=your_random_secret_string

# Credentials used ONLY by the seed script to create your first admin login.
ADMIN_EMAIL=your_admin_email
ADMIN_PASSWORD=your_admin_password

# Cloudinary (free tier) — found on your dashboard at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret